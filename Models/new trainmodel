# Create binary matrix
print("\nCreating binary matrix...")
symptom_cols = [f'Symptom_{i}' for i in range(1, 16)]
binary_records = []

for idx, row in df.iterrows():
    record = {'Disease': row['Disease']}
    for symptom in sorted(all_symptoms):
        present = symptom in [row[col] for col in symptom_cols if row[col]]
        record[symptom] = 1 if present else 0
    binary_records.append(record)

binary_df = pd.DataFrame(binary_records)
