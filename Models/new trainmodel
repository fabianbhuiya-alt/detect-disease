# Generate dataset
def generate_dataset(disease_symptoms_map, max_symptoms_per_row=15):
    records = []
    
    for disease, symptoms in disease_symptoms_map.items():
        # Add the full symptom set
        row = {'Disease': disease}
        for i in range(max_symptoms_per_row):
            col_name = f'Symptom_{i+1}'
            row[col_name] = symptoms[i] if i < len(symptoms) else ''
        records.append(row)
        
        # Add variations (random subsets)
        import random
        num_variations = min(5, len(symptoms))
        for variation in range(num_variations):
            row = {'Disease': disease}
            num_symptoms = random.randint(max(3, len(symptoms)-5), len(symptoms))
            varied_symptoms = random.sample(symptoms, min(num_symptoms, len(symptoms)))
            for i in range(max_symptoms_per_row):
                col_name = f'Symptom_{i+1}'
                row[col_name] = varied_symptoms[i] if i < len(varied_symptoms) else ''
            records.append(row)
    
    return pd.DataFrame(records)

